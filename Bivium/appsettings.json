{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CommanderSettings": {
    "DefaultTheme": "dark",
    "EditableExtensions": [
      ".txt", ".log", ".csv", ".json", ".xml", ".yaml", ".yml", ".toml",
      ".ini", ".cfg", ".conf", ".config", ".env", ".properties",
      ".md", ".rst", ".tex",
      ".html", ".htm", ".css", ".scss", ".less", ".js", ".ts", ".jsx", ".tsx",
      ".cs", ".csx", ".vb", ".fs", ".fsx",
      ".py", ".rb", ".php", ".java", ".kt", ".go", ".rs", ".c", ".cpp", ".h", ".hpp",
      ".sh", ".bash", ".zsh", ".ps1", ".psm1", ".bat", ".cmd",
      ".sql", ".graphql",
      ".dockerfile", ".dockerignore", ".gitignore", ".editorconfig",
      ".sln", ".csproj", ".vbproj", ".fsproj"
    ]
  }
}
